# Shared settings
NODE_ENV=development

# Redis (optional — note port 6381)
REDIS_URL=redis://localhost:6381

# Strapi CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3200

# Strapi rate limit for /api/* per IP (defaults: 60 req / 60s)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Redis password (production). Compose injects via REDIS_URL=redis://:<pwd>@redis:6379
REDIS_PASSWORD=generate-a-long-random-string

# OpenAI key consumed by codelo-cms (agentes IA + covers)
OPENAI_API_KEY=sk-...

# OpenRouter key — only needed if you select a google/gemini-* (Nano Banana) image
# model in Site Settings.
OPENROUTER_API_KEY=
