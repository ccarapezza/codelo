{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Static-content pages editable from the admin (quiénes somos, REPROCANN, contacto…). The web maps fixed routes to well-known slugs."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "content": {
      "type": "richtext",
      "required": true,
      "description": "Markdown body rendered by the web."
    },
    "seoDescription": {
      "type": "text",
      "description": "Meta description for the page (optional)."
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
