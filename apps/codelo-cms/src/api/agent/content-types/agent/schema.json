{
  "kind": "collectionType",
  "collectionName": "agents",
  "info": {
    "singularName": "agent",
    "pluralName": "agents",
    "displayName": "Agent",
    "description": "AI agents that generate or publish posts."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "role": {
      "type": "enumeration",
      "enum": ["director", "redactor", "image-generator", "analyst"],
      "required": true,
      "default": "redactor"
    },
    "instructions": {
      "type": "text"
    },
    "imagePromptTemplate": {
      "type": "text"
    },
    "imageSize": {
      "type": "string",
      "default": "1024x1024"
    },
    "imageQuality": {
      "type": "string",
      "default": "low"
    },
    "topic": {
      "type": "text"
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "schedules": {
      "type": "component",
      "repeatable": true,
      "component": "schedule.run"
    },
    "lastRunAt": {
      "type": "datetime"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post",
      "mappedBy": "generatedByAgent"
    }
  }
}
