HOST=0.0.0.0
PORT=1339
APP_KEYS=replace-with-app-key-1,replace-with-app-key-2
API_TOKEN_SALT=replace-with-api-token-salt
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-with-transfer-token-salt
ENCRYPTION_KEY=replace-with-encryption-key

# Admin session lifespans (seconds)
ADMIN_ACCESS_TOKEN_LIFESPAN=1800
ADMIN_IDLE_REFRESH_TOKEN_LIFESPAN=604800
ADMIN_IDLE_SESSION_LIFESPAN=3600
ADMIN_MAX_REFRESH_TOKEN_LIFESPAN=2592000
ADMIN_MAX_SESSION_LIFESPAN=2592000

# Database configuration (docker-compose.dev.yml exposes postgres on 5435)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_NAME=codelo
DATABASE_USERNAME=codelo
DATABASE_PASSWORD=codelo
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_URL=postgresql://codelo:codelo@localhost:5435/codelo?schema=public

# Cloud settings
STRAPI_ADMIN_BACKEND_URL=http://localhost:1339
STRAPI_TELEMETRY_DISABLED=true
FLAG_NPS=false
FLAG_PROMOTE_EE=false

# Shared secret for internal admin-page endpoints (posts 01-admin routes)
INTERNAL_API_KEY=generate-a-long-random-string

# AI providers (cover image + article generation)
# OpenAI: article text/prompt design AND gpt-image-* / dall-e-3 covers.
OPENAI_API_KEY=sk-...
# Optional: separate key just for image generation (falls back to OPENAI_API_KEY).
OPENAI_IMAGE_API_KEY=
# OpenRouter: only needed for google/gemini-* (Nano Banana) covers.
OPENROUTER_API_KEY=
